{
  "schema_version": 1,
  "name": "opencode",
  "description": "opencode plugin and matching nono profile. Provides sandbox-aware diagnostics on permission failures and ships the opencode profile via the registry.",
  "license": "Apache-2.0",
  "platforms": ["macos", "linux"],
  "min_nono_version": "0.44.0",
  "artifacts": [
    { "type": "profile", "path": "policy.json", "install_as": "opencode" },
    { "type": "plugin", "path": "README.md" },
    { "type": "plugin", "path": "plugin/nono-sandbox.ts" },
    { "type": "plugin", "path": "skills/nono-sandbox/SKILL.md" },
    { "type": "plugin", "path": "wiring/profile-drafts-dir-marker" }
  ],
  "wiring": [
    {
      "type": "write_file",
      "source": "wiring/profile-drafts-dir-marker",
      "dest": "$HOME/.config/nono/profile-drafts/.nono-opencode-pack-marker"
    },
    {
      "type": "symlink",
      "link": "$HOME/.config/opencode/plugins/nono-sandbox.ts",
      "target": "$PACK_DIR/plugin/nono-sandbox.ts"
    },
    {
      "type": "symlink",
      "link": "$HOME/.config/opencode/skills/nono-sandbox",
      "target": "$PACK_DIR/skills/nono-sandbox"
    }
  ]
}
