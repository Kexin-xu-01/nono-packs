{
  "schema_version": 1,
  "name": "codex",
  "description": "OpenAI Codex CLI plugin and matching nono profile. Provides sandbox-aware diagnostics on permission failures via Codex's hook system.",
  "license": "Apache-2.0",
  "platforms": ["macos", "linux"],
  "min_nono_version": "0.43.0",
  "artifacts": [
    {
      "type": "profile",
      "path": "policy.json",
      "install_as": "codex"
    },
    { "type": "plugin", "path": ".codex-plugin/plugin.json" },
    { "type": "plugin", "path": "bin/nono-hook.sh" },
    { "type": "plugin", "path": "bin/nono-hook-permission.sh" },
    { "type": "plugin", "path": "bin/nono-hook-session.sh" },
    { "type": "plugin", "path": "skills/nono-sandbox/SKILL.md" }
  ]
}
