{
  "extends": "default",
  "meta": {
    "name": "copilot-cli",
    "version": "1.0.0",
    "description": "GitHub Copilot CLI — sandboxed session with GitHub token injected from OS keychain",
    "author": "always-further"
  },
  "workdir": {
    "access": "readwrite"
  },
  "security": {
    "groups": [
      "rust_runtime",
      "node_runtime",
      "git_config"
    ]
  },
  "filesystem": {
    "allow": [
      "$HOME/.copilot",
      "$HOME/Library/Caches/copilot",
      "/usr/local/Caskroom/copilot-cli",
      "$HOME/.cache/copilot/"
    ],
    "read": [
      "$HOME/.config/gh",
      "/usr/local/etc/gitconfig"
    ]
  }
}
