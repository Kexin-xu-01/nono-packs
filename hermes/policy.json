{
  "extends": "default",
  "meta": {
    "name": "hermes",
    "version": "1.0.0",
    "description": "Hermes Agent CLI profile (registry-managed)",
    "author": "always-further"
  },
  "groups": {
    "include": [
      "python_runtime",
      "node_runtime",
      "rust_runtime",
      "user_caches_macos",
      "user_caches_linux",
      "linux_sysfs_read",
      "nix_runtime",
      "git_config",
      "unlink_protection"
    ]
  },
  "security": {
    "signal_mode": "isolated",
    "capability_elevation": false
  },
  "filesystem": {
    "allow": [
      "$HOME/.hermes",
      "$HOME/.config/nono/profiles"
    ],
    "read": [
      "$HOME/.local/bin",
      "$HOME/.local/share/uv",
      "$HOME/.config/nono/packages"
    ]
  },
  "network": {
    "block": false,
    "network_profile": "enterprise",
    "credentials": [
      "openai",
      "anthropic",
      "gemini",
      "github",
      "gitlab"
    ],
    "custom_credentials": {
      "openai": {
        "upstream": "https://api.openai.com/v1",
        "credential_key": "openai_api_key",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}",
        "env_var": "OPENAI_API_KEY",
        "endpoint_rules": [
          { "method": "POST", "path": "/chat/completions" },
          { "method": "POST", "path": "/responses" },
          { "method": "POST", "path": "/embeddings" },
          { "method": "POST", "path": "/audio/**" },
          { "method": "POST", "path": "/images/**" },
          { "method": "GET", "path": "/models" },
          { "method": "GET", "path": "/models/**" },
          { "method": "POST", "path": "/v1/chat/completions" },
          { "method": "POST", "path": "/v1/responses" },
          { "method": "POST", "path": "/v1/embeddings" },
          { "method": "POST", "path": "/v1/audio/**" },
          { "method": "POST", "path": "/v1/images/**" },
          { "method": "GET", "path": "/v1/models" },
          { "method": "GET", "path": "/v1/models/**" }
        ]
      },
      "anthropic": {
        "upstream": "https://api.anthropic.com",
        "credential_key": "anthropic_api_key",
        "inject_header": "x-api-key",
        "credential_format": "{}",
        "env_var": "ANTHROPIC_API_KEY",
        "endpoint_rules": [
          { "method": "POST", "path": "/v1/messages" },
          { "method": "POST", "path": "/v1/messages/**" },
          { "method": "POST", "path": "/v1/complete" },
          { "method": "GET", "path": "/v1/models" },
          { "method": "GET", "path": "/v1/models/**" }
        ]
      },
      "gemini": {
        "upstream": "https://generativelanguage.googleapis.com",
        "credential_key": "gemini_api_key",
        "inject_header": "x-goog-api-key",
        "credential_format": "{}",
        "env_var": "GEMINI_API_KEY",
        "endpoint_rules": [
          { "method": "GET", "path": "/v1beta/models" },
          { "method": "GET", "path": "/v1beta/models/**" },
          { "method": "POST", "path": "/v1beta/models/**" },
          { "method": "GET", "path": "/v1/models" },
          { "method": "GET", "path": "/v1/models/**" },
          { "method": "POST", "path": "/v1/models/**" }
        ]
      }
    }
  },
  "workdir": { "access": "readwrite" },
  "open_urls": {
    "allow_localhost": true
  },
  "allow_launch_services": true,
  "undo": {
    "exclude_patterns": [
      "node_modules",
      ".next",
      "__pycache__",
      "target",
      ".hermes"
    ],
    "exclude_globs": ["*.tmp.[0-9]*.[0-9]*"]
  },
  "interactive": true
}
